<Window x:Class="ZoneHydrantEditor.ExportProgressWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Сохранение зон" 
        Width="250" 
        Height="200" 
        WindowStartupLocation="CenterScreen"
        WindowStyle="SingleBorderWindow"
        ResizeMode="NoResize"
        Topmost="True">
    <StackPanel Margin="5">
        <TextBlock Name="ProgressText" Text="Подготовка:" FontSize="14" HorizontalAlignment="Center" VerticalAlignment="Center"/>
        <ProgressBar Name="ProgressBar" Height="20" Margin="5"/>
        <TextBlock Name="StatusText" Text="" FontSize="12" HorizontalAlignment="Center" Margin="5" Foreground="Gray"/>
    </StackPanel>
</Window>