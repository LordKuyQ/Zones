<Window x:Class="ZoneHydrantEditor.UserCreateDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Создание пользователя" Height="500" Width="450"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F5F5">
    
    <StackPanel Margin="10">
        <TextBlock Text="Создание нового пользователя" FontSize="16" FontWeight="Bold" Foreground="#1E1E1E"/>

        <StackPanel>
            <TextBlock Text="Фамилия:" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
            <TextBox x:Name="FamilyTextBox" Height="35" FontSize="14"/>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Имя:" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
            <TextBox x:Name="NameTextBox" Height="35" FontSize="14"/>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Отчество:" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
            <TextBox x:Name="SurnameTextBox" Height="35" FontSize="14"/>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Код города:" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
            <TextBox x:Name="CityCodeTextBox" Height="35" FontSize="14"/>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Код подразделения:" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
            <TextBox x:Name="UnitCodeTextBox" Height="35" FontSize="14"/>
        </StackPanel>

        <StackPanel>
            <TextBlock Text="Должность:" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
            <TextBox x:Name="DutyTextBox" Height="35" FontSize="14"/>
        </StackPanel>

        <StackPanel Grid.Row="8" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена" Width="100" Height="35" Margin="0,0,10,0" 
                    IsCancel="True" Background="#E8E8E8" FontSize="14"/>
            <Button Content="Создать" Width="100" Height="35" 
                    IsDefault="True" Click="CreateButton_Click" 
                    Background="#1E1E1E" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
        </StackPanel>
    </StackPanel>
</Window>