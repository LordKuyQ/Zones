<Window x:Class="ZoneHydrantEditor.InputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Ввод данных"
        Width="300"
        Height="150"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize">
    <StackPanel Margin="5">
        <TextBlock Name="QuestionText" FontWeight="SemiBold" Text="Введите значение:"/>
        <TextBox Name="InputTextBox" Height="25" Margin="5"/>
        <StackPanel Orientation="Horizontal" Margin="5" HorizontalAlignment="Right">
            <Button Name="OkButton" Content="OK" Width="80" Height="30" Margin="5" Click="OkButton_Click"/>
            <Button Name="CancelButton" Content="Отмена" Width="80" Height="30" Click="CancelButton_Click"/>
        </StackPanel>
    </StackPanel>
</Window>