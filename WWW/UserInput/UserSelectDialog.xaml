<Window x:Class="ZoneHydrantEditor.UserSelectDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Выбор пользователя" Height="400" Width="500"
        WindowStartupLocation="CenterScreen" ResizeMode="NoResize"
        Background="#F5F5F5">
    <StackPanel Margin="20">
        <TextBlock Text="Выберите пользователя" 
                   FontSize="18" FontWeight="Bold" 
                   Foreground="#1E1E1E" Margin="0,0,0,20"/>

        <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="10" Margin="0,10"
                BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Пользователь:" FontWeight="SemiBold" Foreground="#555" Margin="0,0,0,5"/>
                <ComboBox x:Name="UserComboBox" DisplayMemberPath="DisplayName" 
                          SelectedValuePath="FioId" Height="35" FontSize="14"/>
            </StackPanel>
        </Border>

        <Border Grid.Row="2" Background="White" CornerRadius="5" Padding="10" Margin="0,10"
                BorderBrush="#DDD" BorderThickness="1">
            <Button x:Name="CreateUserButton" Content="➕ Создать нового пользователя" 
                    Height="40" FontSize="14" FontWeight="SemiBold"
                    Background="#1E1E1E" Foreground="White" Cursor="Hand"
                    Click="CreateUserButton_Click"/>
        </Border>

        <StackPanel Grid.Row="4" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена" Width="100" Height="35" Margin="0,0,10,0" 
                    IsCancel="True" Background="#E8E8E8" FontSize="14"/>
            <Button Content="Выбрать" Width="100" Height="35" 
                    IsDefault="True" Click="SelectUserButton_Click" 
                    Background="#1E1E1E" Foreground="White" FontSize="14" FontWeight="SemiBold"/>
        </StackPanel>
    </StackPanel>
</Window>