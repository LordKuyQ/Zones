<Window x:Class="ZoneHydrantEditor.SyncPage.SyncPageWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Привязки гидрантов"
        Height="700"
        Width="1100"
        WindowStartupLocation="CenterScreen"
        Background="#F5F5F5">
    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <DataGrid x:Name="HydrantsGrid"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  SelectionMode="Single"
                  SelectionUnit="FullRow"
                  SelectionChanged="HydrantsGrid_SelectionChanged"
                  GridLinesVisibility="All"
                  Margin="0,0,0,10">
            <DataGrid.Resources>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="FontWeight" Value="Bold" />
                    <Setter Property="Background" Value="#E8E8E8" />
                    <Setter Property="BorderBrush" Value="#CCC" />
                    <Setter Property="BorderThickness" Value="0,0,1,1" />
                    <Setter Property="Padding" Value="5" />
                    <Setter Property="Height" Value="35" />
                    <Setter Property="HorizontalContentAlignment" Value="Center" />
                </Style>
                <Style TargetType="DataGridCell">
                    <Setter Property="Padding" Value="5" />
                    <Setter Property="VerticalAlignment" Value="Center" />
                </Style>
            </DataGrid.Resources>
            <DataGrid.Columns>
                <DataGridTextColumn Header="Номер" Binding="{Binding EwsNumber}" Width="80" />
                <DataGridTextColumn Header="Адрес" Binding="{Binding AddressText}" Width="200" />
                <DataGridTextColumn Header="Привязка (коорд.)" Binding="{Binding EwsPriviazka}" Width="180" />
                <DataGridTextColumn Header="X (м)" Binding="{Binding EwsPriviazkaGeoX}" Width="80" />
                <DataGridTextColumn Header="Y (м)" Binding="{Binding EwsPriviazkaGeoY}" Width="80" />
                <DataGridTextColumn Header="Влево (м)" Binding="{Binding EwsPrLeft}" Width="80" />
                <DataGridTextColumn Header="Вправо (м)" Binding="{Binding EwsPrRight}" Width="80" />
                <DataGridTextColumn Header="Прямо (м)" Binding="{Binding EwsPrStright}" Width="80" />
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="15" Margin="0,0,0,10"
                BorderBrush="#DDD" BorderThickness="1">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <TextBlock Text="Гидрант:" FontWeight="SemiBold" Margin="0,0,10,5" VerticalAlignment="Center" />
                    <TextBox x:Name="HydrantNumberText" Grid.Column="1" IsReadOnly="True" Background="#F0F0F0" Margin="0,0,20,5" />

                    <TextBlock Text="Координаты (lat,lng):" FontWeight="SemiBold" Grid.Column="2" Margin="0,0,10,5" VerticalAlignment="Center" />
                    <TextBox x:Name="PriviazkaTextBox" Grid.Column="3" TextChanged="PriviazkaTextBox_TextChanged" Margin="0,0,0,5" ToolTip="Введите координаты привязки в формате: широта,долгота" />

                    <TextBlock Text="X (м):" FontWeight="SemiBold" Grid.Row="1" Margin="0,0,10,5" VerticalAlignment="Center" />
                    <TextBox x:Name="GeoXText" Grid.Row="1" Grid.Column="1" IsReadOnly="True" Background="#F0F0F0" Margin="0,0,20,5" />

                    <TextBlock Text="Y (м):" FontWeight="SemiBold" Grid.Row="1" Grid.Column="2" Margin="0,0,10,5" VerticalAlignment="Center" />
                    <TextBox x:Name="GeoYText" Grid.Row="1" Grid.Column="3" IsReadOnly="True" Background="#F0F0F0" Margin="0,0,0,5" />

                    <TextBlock Text="Расстояния:" FontWeight="SemiBold" Grid.Row="2" Margin="0,0,10,0" VerticalAlignment="Center" Foreground="#888" />
                    <StackPanel Grid.Row="2" Grid.Column="1" Grid.ColumnSpan="3" Orientation="Horizontal" Margin="0,5,0,0">
                        <TextBlock Text="Влево:" Margin="0,0,5,0" VerticalAlignment="Center" />
                        <TextBox x:Name="PrLeftText" Width="80" Margin="0,0,15,0" IsReadOnly="True" Background="#F0F0F0" />
                        <TextBlock Text="Вправо:" Margin="0,0,5,0" VerticalAlignment="Center" />
                        <TextBox x:Name="PrRightText" Width="80" Margin="0,0,15,0" IsReadOnly="True" Background="#F0F0F0" />
                        <TextBlock Text="Прямо:" Margin="0,0,5,0" VerticalAlignment="Center" />
                        <TextBox x:Name="PrStrightText" Width="80" IsReadOnly="True" Background="#F0F0F0" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="20,0,0,0">
                    <Button Content="Установить привязку" Width="160" Height="35" Margin="0,0,10,0"
                            Background="#1E1E1E" Foreground="White" FontWeight="SemiBold"
                            Click="SetBindingButton_Click" />
                    <Button Content="Очистить привязку" Width="140" Height="35"
                            Background="#E8E8E8" FontWeight="SemiBold"
                            Click="ClearBindingButton_Click" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2" Background="#FFE0E0" CornerRadius="5" Padding="10"
                BorderBrush="#FFCCC" BorderThickness="1">
            <TextBlock x:Name="InfoText"
                       Text="Выберите гидрант из списка, введите координаты привязки (широта,долгота). Расстояния рассчитаются автоматически."
                       Foreground="#CC0000" FontWeight="SemiBold" TextWrapping="Wrap" />
        </Border>
    </Grid>
</Window>
