<Window x:Class="ZoneHydrantEditor.TitlePageDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:sys="clr-namespace:System;assembly=mscorlib"
        Title="Заполнение титульного листа" Height="803" Width="550"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
        Background="#F5F5F5">
    <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Данные для титульного листа планшета водоисточников" 
                   FontSize="16" FontWeight="Bold" Margin="0,0,0,20" 
                   Foreground="#1E1E1E"/>

        <!-- Дата составления -->
        <Border Grid.Row="1" Background="White" CornerRadius="5" Padding="10" Margin="0,5" 
                BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Дата составления:" FontWeight="SemiBold" Foreground="#555"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="DayTextBox" Text="" Width="40" TextAlignment="Center"
                             VerticalContentAlignment="Center" FontSize="14"/>
                    <TextBlock Grid.Column="1" Text="________" VerticalAlignment="Center" Margin="5,0"/>
                    <TextBox x:Name="MonthTextBox" Width="100" TextAlignment="Center"
                             VerticalContentAlignment="Center" FontSize="14" Grid.Column="2"/>
                    <TextBlock Grid.Column="3" Text="2026" VerticalAlignment="Center" FontSize="14" 
                               FontWeight="Bold" Margin="5,0"/>
                    <TextBlock Grid.Column="4" Text="г." VerticalAlignment="Center" FontSize="14" Margin="5,0"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Количество экземпляров -->
        <Border Grid.Row="2" Background="White" CornerRadius="5" Padding="10" Margin="0,5" 
                BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Количество экземпляров:" FontWeight="SemiBold" Foreground="#555"/>
                <TextBox x:Name="CopiesCountTextBox" Text="" Width="80" HorizontalAlignment="Left"
                         TextAlignment="Center" FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- ФИО начальника -->
        <Border Grid.Row="3" Background="White" CornerRadius="5" Padding="10" Margin="0,5" 
                BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Начальник (ФИО):" FontWeight="SemiBold" Foreground="#555"/>
                <TextBox x:Name="ChiefNameTextBox" Text="А. А. Стасеев" FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Звание -->
        <Border Grid.Row="4" Background="White" CornerRadius="5" Padding="10" Margin="0,5" 
                BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Звание:" FontWeight="SemiBold" Foreground="#555"/>
                <TextBox x:Name="RankTextBox" Text="майор внутренней службы" FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Должность -->
        <Border Grid.Row="5" Background="White" CornerRadius="5" Padding="10" Margin="0,5" 
                BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Должность:" FontWeight="SemiBold" Foreground="#555"/>
                <TextBox x:Name="PositionTextBox" 
                         Text="Начальник 37 ПСЧ 3 ПСО ФПС ГПС ГУ МЧС по Новосибирской области" 
                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="50" FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Составитель -->
        <Border Grid.Row="6" Background="White" CornerRadius="5" Padding="10" Margin="0,5" 
                BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Составитель (должность и ФИО):" FontWeight="SemiBold" Foreground="#555"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="CompilerPositionTextBox" 
                             Text="Начальник караула 37 ПСЧ 3 ПСО ФПС ГПС ГУ по Новосибирской области"
                             TextWrapping="Wrap" AcceptsReturn="True" MinHeight="50" FontSize="14"/>
                    <TextBlock Grid.Column="1" Text="________" VerticalAlignment="Center" Margin="10,0" 
                               FontSize="14"/>
                    <TextBox x:Name="CompilerNameTextBox" Grid.Column="2" 
                             Text="С.Н. Шелестов" FontSize="14" VerticalContentAlignment="Center"/>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Название документа -->
        <Border Grid.Row="7" Background="White" CornerRadius="5" Padding="10" Margin="0,5" 
                BorderBrush="#DDD" BorderThickness="1">
            <StackPanel>
                <TextBlock Text="Название планшета:" FontWeight="SemiBold" Foreground="#555"/>
                <TextBox x:Name="TitleTextTextBox" 
                         Text="ПЛАНШЕТ ВОДОИСТОЧНИКОВ Р. П. КРАСНООБСК, П. ЭЛИТНЫЙ И СНТ «СОЛНЕЧНЫЙ» РАЙОНА ВЫЕЗДА 37 ПСЧ"
                         TextWrapping="Wrap" AcceptsReturn="True" MinHeight="60" FontSize="14"/>
            </StackPanel>
        </Border>

        <!-- Кнопки -->
        <StackPanel Grid.Row="9" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,20,0,0">
            <Button Content="Отмена" Width="100" Height="35" Margin="0,0,10,0" 
                    IsCancel="True" Background="#E8E8E8" FontSize="14"/>
            <Button Content="Создать титульный лист" Width="180" Height="35" 
                    IsDefault="True" Click="OkButton_Click" Background="#1E1E1E" 
                    Foreground="White" FontSize="14" FontWeight="SemiBold"/>
        </StackPanel>
    </Grid>
</Window>